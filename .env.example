# WebBridge MCP Configuration
# Copy to .env and fill in values

## Server Mode
WEBBRIDGE_MODE=http              # http or stdio
WEBBRIDGE_PORT=3456
WEBBRIDGE_HOST=0.0.0.0

## Authentication (REQUIRED for http mode)
WEBBRIDGE_AUTH_TOKEN=wbr_your-secret-api-key-here

## Browser Engine
CHROME_PATH=                     # Auto-detected if empty
WEBBRIDGE_STEALTH_LEVEL=stealth  # basic, standard, stealth
WEBBRIDGE_HEADLESS=new           # true, false, or "new" (Chrome headless mode)

## Session & Data Persistence
WEBBRIDGE_DATA_DIR=./data

## Performance
WEBBRIDGE_MAX_CONCURRENCY=5
WEBBRIDGE_TYPING_DELAY_MS=50

## Proxy (optional)
# WEBBRIDGE_PROXY_URL=socks5://user:pass@host:1080

## Rate Limiting
WEBBRIDGE_RATE_LIMIT_MAX=60     # requests per minute per IP
